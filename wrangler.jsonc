{
  // CloudFlare Workers — static-assets-only deployment (no Worker script).
  // Docs: https://developers.cloudflare.com/workers/static-assets/
  "name": "openvaultdb-com",
  "compatibility_date": "2025-09-01",
  "assets": {
    "directory": "./public",
    // Single landing page: serve index.html, return its 404 page otherwise.
    "not_found_handling": "404-page",
    // Redirect /index.html and trailing-slash variants to clean URLs.
    "html_handling": "auto-trailing-slash"
  }
}
